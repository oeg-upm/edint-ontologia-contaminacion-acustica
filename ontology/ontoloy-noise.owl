    <!-- http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/emitterPredominantType -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/emitterPredominantType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/NoiseObservation"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/EmitterPredominantType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Property that links a noise observation to its predominant type of emitter</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una observación acústica a su tipo predominante de emisor</rdfs:comment>
        <rdfs:label xml:lang="en">pedominant type of noise emitter</rdfs:label>
        <rdfs:label xml:lang="es">tipo de emisor de ruido predominante</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/noiseRateType -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/noiseRateType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/NoiseObservation"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/NoiseRateType/"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Property that links a noise observation to its type of noise or vibration rate</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una observación acústica a su tipo de índice de ruido o vibración</rdfs:comment>
        <rdfs:label xml:lang="es">tipo de índice de ruido o vibración</rdfs:label>
        <rdfs:label xml:lang="en">type of noise or vibration rate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/referenceInterval -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/referenceInterval">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/NoiseObservation"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/ReferenceInterval"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Property that links a noise observation to its type of measurement period</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula una observación acústica a su periodo de medión</rdfs:comment>
        <rdfs:label xml:lang="es">intervalo de referencia</rdfs:label>
        <rdfs:label xml:lang="en">reference interval</rdfs:label>
    </owl:ObjectProperty>
    


