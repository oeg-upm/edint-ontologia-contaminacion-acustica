    <!-- http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/NoiseObservation -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/NoiseObservation">
