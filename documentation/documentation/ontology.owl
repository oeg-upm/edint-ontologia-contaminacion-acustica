    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/">
        <owl:imports rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/"/>
        <terms:creator xml:lang="es">Daniel Doña</terms:creator>
        <terms:creator>Edna Ruckhaus</terms:creator>
        <terms:creator>Lucía Sánchez</terms:creator>
        <terms:creator>Maria del Socorro Bernardos</terms:creator>
        <terms:creator>Oscar Corcho</terms:creator>
        <terms:description xml:lang="en">A lightweight ontology extending the medioambiente EDIT Ontology to represent noise pollution, restricting their observations to the EDINT SKOS controlled vocabulary.</terms:description>
        <terms:description xml:lang="es">Una ontología ligera que extiende la ontología EDINT de medioambiente para representar contaminación acústica, restringiendo sus mediciones al vocabulario controlado SKOS de EDINT.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-27</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-27</terms:modified>
        <terms:title xml:lang="en">EDINT Noise Pollution Ontology</terms:title>
        <terms:title xml:lang="es">Ontología EDINT de Contaminación Acústica</terms:title>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


