@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintmed: <http://vocab.linkeddata.es/datosabiertos/def/medioambiente#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .

@prefix edintemittertype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/EmitterPredominantType/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:EmitterPredominantType a skos:ConceptScheme ; 
    dct:issued "2026-03-27"^^xsd:date ;
    dct:modified "2026-03-27"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT"@es ;
    rdfs:label "Pedominant type of noise emitter"@en ;
    rdfs:label "Tipo de emisor de ruido predominante"@es ;
    dct:title "Concept scheme grouping types of noise or vibration emitters based on the list obtained in Article 12.2 of Law 37/2003, of November 17, on Noise"@en ;
    dct:title "Esquema de conceptos que agrupa tipos de emisores de ruido o vibración basada en el listado obtenido en el artículo 12.2 de la Ley 37/2003, de 17 de noviembre, del Ruido"@es ;
    skos:note "Values currently based on the list of values included in http://vocab.linkeddata.es/datosabiertos/kos/medio-ambiente/contaminacion-acustica/tipo-intervalo-referencia"@en;
    skos:note "Valores basados inicialmente en la lista de valores de http://vocab.linkeddata.es/datosabiertos/kos/medio-ambiente/contaminacion-acustica/tipo-intervalo-referencia"@es.

#################################################################
#
#    Concepts
#
#################################################################

edintemittertype:motorvehicle a skos:Concept ;
  skos:inScheme edintkos:EmitterPredominantType ;
  skos:prefLabel "motor vehicle"@en ;
  skos:prefLabel "vehículos automóviles"@es ;
  skos:definition "Contaminación acústica provocada por un emisor de tipo vehículo automóvil"@es ;
  skos:definition "Noise pollution caused by a motor vehicle emitter"@en .

