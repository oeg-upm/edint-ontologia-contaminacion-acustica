@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintmed: <http://vocab.linkeddata.es/datosabiertos/def/medioambiente#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .

@prefix edintreferenceinterval: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ReferenceInterval/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:ReferenceInterval a skos:ConceptScheme ; 
    dct:issued "2026-03-27"^^xsd:date ;
    dct:modified "2026-03-27"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Reference interval"@en ;
    rdfs:label "Intervalo de referencia"@es ;
    dct:title "Concept scheme grouping types of mesaurement periods for noise observations"@en ;
    dct:title "Esquema de conceptos que agrupa tipos de periodos de medición para observaciones de calidad acústica"@es ;
    skos:note "Values currently based on the list of values included in http://vocab.linkeddata.es/datosabiertos/kos/medio-ambiente/contaminacion-acustica/tipo-intervalo-referencia"@en;
    skos:note "Valores basados inicialmente en la lista de valores de http://vocab.linkeddata.es/datosabiertos/kos/medio-ambiente/contaminacion-acustica/tipo-intervalo-referencia"@es.

#################################################################
#
#    Concepts
#
#################################################################

edintreferenceinterval:T a skos:Concept ;
  skos:inScheme edintkos:ReferenceInterval ;
  skos:prefLabel "T"@en ;
  skos:prefLabel "T"@es ;
  skos:definition "Indicador del nivel de ruido global durante el día, la tarde y la noche, utilizado para determinar la molestia vinculada a la exposición al ruido"@es ;
  skos:definition "Day-evening-night noise level indicator, used to determine annoyance related to noise exposure"@en .

edintreferenceinterval:D a skos:Concept ;
  skos:inScheme edintkos:ReferenceInterval ;
  skos:prefLabel "D"@en ;
  skos:prefLabel "D"@es ;
  skos:definition "Nivel sonoro medio a largo plazo ponderado A, determinado a lo largo de todos los períodos día (de 7 a 19 horas) del mes"@es ;
  skos:definition "Long-term A-weighted average sound level, determined over all the daytime periods (from 7:00 to 19:00) of the month"@en .

edintreferenceinterval:E a skos:Concept ;
  skos:inScheme edintkos:ReferenceInterval ;
  skos:prefLabel "E"@en ;
  skos:prefLabel "E"@es ;
  skos:definition "Nivel sonoro medio a largo plazo ponderado A, determinado a lo largo de todos los períodos tarde (de 19 a 23 horas) del mes"@es ;
  skos:definition "Long-term A-weighted average sound level, determined over all the daytime periods (from 19:00 to 23:00) of the month"@en .
  
edintreferenceinterval:N a skos:Concept ;
  skos:inScheme edintkos:ReferenceInterval ;
  skos:prefLabel "N"@en ;
  skos:prefLabel "N"@es ;
  skos:definition "Nivel sonoro medio a largo plazo ponderado A, definido determinado a lo largo de todos los períodos noche (de 23 a 7 horas) del mes"@es ;
  skos:definition "Long-term A-weighted average sound level, determined over all the night-time periods (from 23:00 to 7:00) of the month"@en .