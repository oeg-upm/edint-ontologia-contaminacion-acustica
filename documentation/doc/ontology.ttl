#################################################################
#    Object Properties
#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/emitterPredominantType
:emitterPredominantType rdf:type owl:ObjectProperty ;
                        rdfs:domain :NoiseObservation ;
                        rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                            owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/EmitterPredominantType>
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
                        rdfs:comment "Property that links a noise observation to its predominant type of emitter"@en ,
                                     "Vincula una observación acústica a su tipo predominante de emisor"@es ;
                        rdfs:label "pedominant type of noise emitter"@en ,
                                   "tipo de emisor de ruido predominante"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/noiseRateType
:noiseRateType rdf:type owl:ObjectProperty ;
               rdfs:domain :NoiseObservation ;
               rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                   owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/NoiseRateType/>
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
               rdfs:comment "Property that links a noise observation to its type of noise or vibration rate"@en ,
                            "Vincula una observación acústica a su tipo de índice de ruido o vibración"@es ;
               rdfs:label "tipo de índice de ruido o vibración"@es ,
                          "type of noise or vibration rate"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/referenceInterval
:referenceInterval rdf:type owl:ObjectProperty ;
                   rdfs:domain :NoiseObservation ;
                   rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                       owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/ReferenceInterval>
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
                   rdfs:comment "Property that links a noise observation to its type of measurement period"@en ,
                                "Vincula una observación acústica a su periodo de medión"@es ;
                   rdfs:label "intervalo de referencia"@es ,
                              "reference interval"@en .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty .


