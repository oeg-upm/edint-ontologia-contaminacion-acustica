###  http://vocab.linkeddata.es/datosabiertos/def/contaminacionacustica/NoiseObservation
:NoiseObservation rdf:type owl:Class ;
                  rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalObservation> ;
                  rdfs:comment "An observation of a noise property made by a noise sensor"@en ,
                               "Una observación de una propiedad acústica realizada por un sensor acústico"@es ;
                  rdfs:label "Noise observation"@en ,
                             "Observación acústica"@es .


